# ─── Server Configuration ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jmd-refrigeration?retryWrites=true&w=majority

# ─── Frontend URL (for CORS) ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Business Info ───────────────────────────────────────────────────
BUSINESS_PHONE=9999999999

# ─── Twilio (for WhatsApp/SMS reminders) ─────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
# For WhatsApp sandbox: https://www.twilio.com/console/sms/whatsapp/sandbox
# If left blank, reminders will be SIMULATED (logged to console only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1XXXXXXXXXX
